{
  "manifest_version": 3,
  "name": "Camera Feed Interceptor",
  "version": "1.0.0",
  "description": "Intercepts getUserMedia to replace live camera feed with pre-recorded video",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["test-pages/*"],
      "matches": ["<all_urls>", "file:///*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Camera Interceptor"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
